{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/home/dima/.claude/mnemo/bin/mnemo ingest",
            "timeout": 60
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "/home/dima/.claude/mnemo/bin/mnemo hook-postedit",
            "timeout": 60
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/home/dima/.claude/mnemo/bin/mnemo hook-inject",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
